# Image to deploy (prebuilt and pushed to a registry)
# e.g. ghcr.io/<owner>/tavi-analytics-pdf-render:latest or your-private-registry/tavi-analytics/pdf-render:tag
IMAGE=tavi-analytics/pdf-render:latest

# Host port exposed -> container 8080
PORT=8080

# Internal output directory inside the container
PDF_OUT_DIR=/app/out
